{
    "model_name": "ConcreteVoiceFixer",
    "model_dir": "exp/concrete_v1",

    "task": {
        "_doc": "父类 gsr_voicefixer.py L48/L51/L54/L65/L244 硬读取",
        "inspect_training_data": false,
        "gsr": {
            "gsr_model": {
                "voicefixer": {
                    "unet": true,
                    "unet_small": false,
                    "bi_lstm": false,
                    "dnn": false
                }
            }
        }
    },

    "data": {
        "sampling_rate": 44100,
        "segment_length": 132300,
        "train_dataset": {
            "speech": {
                "vocal": "/root/autodl-tmp/Train_set_speech/wav48/train",
                "noise": "/root/autodl-tmp/Train_set_noise/vd_noise"
            }
        },
        "val_dataset": {
            "speech": {
                "vocal": "/root/autodl-tmp/Train_set_speech/wav48/test",
                "noise": "/root/autodl-tmp/Val_set_concrete_static/vocal_damaged"
            }
        }
    },

    "model": {
        "_doc": "父类 gsr_voicefixer.py L50/L53/L55/L66/L126-L137 硬读取",
        "channels": 1,
        "channels_in": 1,
        "type_target": "vocals",
        "nsrc": 1,
        "loss_type": "l1",
        "mel_freq_bins": 128,
        "window_size": 2048,
        "hop_size": 512,
        "pad_mode": "reflect",
        "window": "hann"
    },

    "mel": {
        "n_fft": 2048,
        "hop_length": 512,
        "win_length": 2048,
        "n_mels": 128,
        "fmin": 0,
        "fmax": 22050
    },

    "augment": {
        "_doc": "重新激活 Phase 1: 恢复 Voicefixer 的抗混响和通用降噪先验",
        "effects": {
            "reverb": {"prob": 0.5}
        },
        "params": {
            "rir_root": "/root/autodl-tmp/Train_and_test_set_RIR/RIR_44k/train"
        }
    },

    "train": {
        "_doc": "基于双卡 4090 优化，若 OOM 请将 batch_size 减半",
        "max_epoches": 200,
        "batch_size": 72,
        "accumulate_grad_batches": 1,
        "learning_rate": 8e-5,
        "lr_decay": 0.999,
        "warmup_steps": 1000,
        "input_segment_length": 132300,
        "reduce_lr_every_n_steps": 5000,
        "check_val_every_n_epoch": 2,
        "num_workers": 12,
        "pin_memory": true,
        "persistent_workers": true,
        "prefetch_factor": 4,
        "save_top_k": 3,
        "early_stop_patience": 10,
        "detect_anomaly": false,
        "resume_from_checkpoint":"/root/autodl-tmp/myvoicefixer/logs/train_concrete/version_11/checkpoints/stage3_epoch=549-step=156200-val_loss=0.2139.ckpt"
    },

    "log": {
        "progress_bar_refresh_rate": 10,
        "log_every_n_steps": 50,
        "visual_max_samples": 3,
        "visual_every_n_epochs": 1
    },

    "concrete": {
        "_doc_pretrained": "VoiceFixer 预训练权重路径",
        "concrete_ratio": 0.7,
        "pretrained_weights": {
            "analysis_module": {
                "path": "/root/autodl-tmp/voicefixer/analysis_module/checkpoints/vf.ckpt",
                "freeze_encoder_layers": 4,
                "trainable": true
            },
            "synthesis_module": {
                "path": "/root/autodl-tmp/voicefixer/synthesis_module/44100/model.ckpt-1490000_trimed.pt",
                "freeze": true,
                "trainable": false
            }
        },

        "concrete_rir_dir": "/root/autodl-tmp/CIRwav",
        "default_phase2_intensity": 0.5,
        "grad_clip_norm": 5.0,

        "freeze_strategy": {
            "freeze_vocoder": false,
            "freeze_encoder_layers": 0
        },

        "optimizer": {
            "base_lr": 1e-5,
            "weight_decay": 1e-4,
            "lr_multipliers": {
                "encoder": 0.5,
                "bottleneck": 0.5,
                "decoder": 0.5,
                "other": 1.0 
            }
        },

        "scheduler": {
            "T_0": 30,
            "T_mult": 2,
            "eta_min": 1e-7
        },

        "curriculum_stages": [
            {
                "_comment": "Stage 1: 简单 - 建立基础修复能力",
                "name": "stage1_easy",
                "epochs": 40,
                "phase2_intensity": 0.3,
                "physics_config": {
                    "jfet_gain": 0.0,
                    "jfet_harmonic": 0.0,
                    "emi_snr_db": [25, 40],
                    "emi_freqs": [50],
                    "demod_lpf_cutoff": 8000
                },
                "collator_config": {
                    "cutoff_range": [3000, 4500],
                    "apply_prob": 0.7
                },
                "unfreeze_encoder_layers": 0,
                "lr_scale": 1.0
            },
            {
                "_comment": "Stage 2: 中等 - 增加物理模拟复杂度",
                "name": "stage2_medium",
                "epochs": 60,
                "phase2_intensity": 0.65,
                "physics_config": {
                    "jfet_gain": 0.6,
                    "jfet_harmonic": 0.06,
                    "emi_snr_db": [15, 30],
                    "emi_freqs": [50, 1000],
                    "demod_lpf_cutoff": 6000
                },
                "collator_config": {
                    "cutoff_range": [2000, 3500],
                    "apply_prob": 0.85
                },
                "unfreeze_encoder_layers": 2,
                "lr_scale": 0.8
            },
            {
                "_comment": "Stage 3: 困难 - 应对极端失真",
                "name": "stage3_hard",
                "epochs": 150,
                "phase2_intensity": 1.0,
                "physics_config": {
                    "jfet_gain": 1.2,
                    "jfet_harmonic": 0.15,
                    "emi_snr_db": [5, 20],
                    "emi_freqs": [50, 1000, 2048],
                    "demod_lpf_cutoff": 4000
                },
                "collator_config": {
                    "cutoff_range": [1500, 2500],
                    "apply_prob": 1.0
                },
                "unfreeze_encoder_layers": 6,
                "lr_scale": 0.5
            },
            {
                "_comment": "Stage 4: 全链路联合微调 - 最终质量打磨",
                "name": "stage4_finetune",
                "epochs": 100,
                "phase2_intensity": 0.7,
                "physics_config": {
                    "jfet_gain": 0.8,
                    "jfet_harmonic": 0.1,
                    "emi_snr_db": [10, 30],
                    "emi_freqs": [50, 1000, 2048],
                    "demod_lpf_cutoff": 4000
                },
                "collator_config": {
                    "cutoff_range": [1500, 2500],
                    "apply_prob": 0.85
                },
                "unfreeze_encoder_layers": 999,
                "lr_scale": 0.05
            }
        ]
    }
}